{
  "name": "@react-ai-stream/core",
  "version": "0.1.0",
  "description": "Provider-agnostic streaming engine and message store for react-ai-stream",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "repository": { "type": "git", "url": "https://github.com/trimooo/react-ai-stream.git", "directory": "packages/core" },
  "homepage": "https://github.com/trimooo/react-ai-stream#readme",
  "bugs": { "url": "https://github.com/trimooo/react-ai-stream/issues" },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "rimraf": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
