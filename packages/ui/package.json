{
  "name": "@react-ai-stream/ui",
  "version": "0.1.0",
  "description": "Pre-built UI components for react-ai-stream",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/base.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "repository": { "type": "git", "url": "https://github.com/trimooo/react-ai-stream.git", "directory": "packages/ui" },
  "homepage": "https://github.com/trimooo/react-ai-stream#readme",
  "bugs": { "url": "https://github.com/trimooo/react-ai-stream/issues" },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@react-ai-stream/core": "workspace:*",
    "@react-ai-stream/react": "workspace:*",
    "highlight.js": "^11.0.0",
    "react-markdown": "^9.0.0",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@react-ai-stream/core": "workspace:*",
    "@react-ai-stream/react": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
