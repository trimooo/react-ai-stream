# Upstash Redis — same instance as playground (different env var names)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Admin secret — must match ADMIN_SECRET in apps/playground/.env.local
ADMIN_SECRET=rais_admin_sk_...

# ─── Provider API keys ────────────────────────────────────────────────────────
# FREE — get at console.groq.com (no credit card)
GROQ_API_KEY=gsk_...

# FREE — get at aistudio.google.com/app/apikey (no credit card)
GEMINI_API_KEY=AIza...

# PAID — only add if you have a paid account
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
